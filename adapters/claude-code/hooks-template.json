{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "punkgo-jack ingest --source claude-code --quiet",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "punkgo-jack ingest --source claude-code --quiet",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "punkgo-jack ingest --source claude-code --event-type session_start --quiet",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "punkgo-jack ingest --source claude-code --event-type session_end --quiet",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
